# Authentication (required for self-hosted deployments, optional for local dev)
# If AUTH_USERNAME is not set the app runs without a login gate — only do this locally.
#
# Generate a bcrypt password hash:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
AUTH_USERNAME=admin
AUTH_NAME=Admin
AUTH_PASSWORD_HASH=$2b$12$replacethiswitharealhash
AUTH_COOKIE_KEY=change-this-to-a-long-random-secret
AUTH_COOKIE_NAME=foodie_auth
